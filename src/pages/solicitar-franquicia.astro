---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Header />
  <main class="bg-[#f5f8fb] min-h-screen py-20">
    <div class="tcp-container">
      <div class="max-w-[600px] mx-auto">
        <h1 class="text-[38px] font-bold text-[#003450] leading-[110%] mb-3">
          Solicitar franquicia
        </h1>
        <p class="text-[#003450]/70 text-[18px] mb-10">
          Completá el formulario y nos ponemos en contacto a la brevedad.
        </p>

        <form
          id="franquicia-form"
          class="bg-white rounded-[20px] p-8 shadow-sm flex flex-col gap-5"
        >
          <div class="flex flex-col gap-1">
            <label class="font-semibold text-[#003450] text-[14px]" for="nombre">
              Nombre y apellido <span class="text-red-500">*</span>
            </label>
            <input
              id="nombre"
              name="nombre"
              type="text"
              required
              placeholder="Juan García"
              class="border border-gray-200 rounded-xl px-4 py-3 text-[#003450] focus:outline-none focus:border-[#02669A] transition"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label class="font-semibold text-[#003450] text-[14px]" for="email">
              Email <span class="text-red-500">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="juan@email.com"
              class="border border-gray-200 rounded-xl px-4 py-3 text-[#003450] focus:outline-none focus:border-[#02669A] transition"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label class="font-semibold text-[#003450] text-[14px]" for="telefono">
              Teléfono <span class="text-red-500">*</span>
            </label>
            <input
              id="telefono"
              name="telefono"
              type="tel"
              required
              placeholder="+54 11 1234-5678"
              class="border border-gray-200 rounded-xl px-4 py-3 text-[#003450] focus:outline-none focus:border-[#02669A] transition"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label class="font-semibold text-[#003450] text-[14px]" for="ciudad">
              Ciudad / Provincia de interés <span class="text-red-500">*</span>
            </label>
            <input
              id="ciudad"
              name="ciudad"
              type="text"
              required
              placeholder="Buenos Aires"
              class="border border-gray-200 rounded-xl px-4 py-3 text-[#003450] focus:outline-none focus:border-[#02669A] transition"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label class="font-semibold text-[#003450] text-[14px]" for="mensaje">
              Mensaje (opcional)
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="4"
              placeholder="Contanos algo sobre vos o tu consulta..."
              class="border border-gray-200 rounded-xl px-4 py-3 text-[#003450] focus:outline-none focus:border-[#02669A] transition resize-none"
            ></textarea>
          </div>

          <div id="form-feedback" class="hidden text-[15px] font-semibold rounded-xl px-4 py-3"></div>

          <button
            type="submit"
            id="submit-btn"
            class="cs-btn --secondary w-full text-center mt-2"
          >
            Enviar solicitud
          </button>
        </form>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('franquicia-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    feedback.classList.add('hidden');

    try {
      const res = await fetch('/api/franquicia', {
        method: 'POST',
        body: new FormData(form),
      });
      const json = await res.json();

      feedback.classList.remove('hidden', 'bg-green-100', 'text-green-700', 'bg-red-100', 'text-red-700');

      if (json.ok) {
        feedback.classList.add('bg-green-100', 'text-green-700');
        feedback.textContent = '¡Solicitud enviada correctamente! Nos contactamos pronto.';
        form.reset();
        submitBtn.textContent = 'Enviado ✓';
      } else {
        feedback.classList.add('bg-red-100', 'text-red-700');
        feedback.textContent = json.error ?? 'Ocurrió un error. Intentá de nuevo.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar solicitud';
      }
    } catch {
      feedback.classList.remove('hidden');
      feedback.classList.add('bg-red-100', 'text-red-700');
      feedback.textContent = 'Error de conexión. Revisá tu internet e intentá de nuevo.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar solicitud';
    }
  });
</script>
